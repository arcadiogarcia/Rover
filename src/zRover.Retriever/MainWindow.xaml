<Window
    x:Class="zRover.Retriever.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    Title="zRover Retriever">

    <Grid>
        <Grid.Resources>

            <!-- Fluent card: layered fill, 1px stroke, 8px radius. -->
            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="20"/>
            </Style>

            <!-- Inline/secondary card (e.g. QR container inside External access). -->
            <Style x:Key="SubCardBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}"/>
                <Setter Property="Padding" Value="14"/>
            </Style>

            <!-- Section title: BodyStrong, used next to an InfoBadge count. -->
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock"
                   BasedOn="{StaticResource BodyStrongTextBlockStyle}">
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <!-- Caption used for description text under a row title or eyebrow. -->
            <Style x:Key="CaptionMutedStyle" TargetType="TextBlock"
                   BasedOn="{StaticResource CaptionTextBlockStyle}">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <!-- Monospaced URL/token for unambiguous rendering. -->
            <Style x:Key="MonoTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Consolas, Cascadia Mono, Segoe UI Mono"/>
                <Setter Property="IsTextSelectionEnabled" Value="True"/>
            </Style>

            <!-- Read-only list: no selection visuals, tight rows, transparent bg. -->
            <Style x:Key="FlatListViewStyle" TargetType="ListView">
                <Setter Property="SelectionMode" Value="None"/>
                <Setter Property="IsItemClickEnabled" Value="False"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
            </Style>

        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ==================== TITLE BAR ==================== -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="40" Padding="16,0,0,0">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/Square44x44Logo.targetsize-24.png"
                       Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="zRover Retriever"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"/>
                <TextBlock x:Name="AppVersionText"
                           Text=""
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ==================== BODY (scrollable) ==================== -->
        <ScrollViewer Grid.Row="1"
                      Padding="32,4,32,32"
                      HorizontalContentAlignment="Center"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollMode="Disabled">
            <StackPanel x:Name="BodyPanel" Spacing="20" MaxWidth="1200" HorizontalAlignment="Center">

                <!-- ========== HERO ========== -->
                <Border Style="{StaticResource CardBorderStyle}" Padding="24">
                    <Grid ColumnSpacing="20" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Local MCP endpoint"
                                   Style="{StaticResource CaptionMutedStyle}"/>

                        <Border Grid.Row="0" Grid.Column="1"
                                Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                BorderBrush="{ThemeResource SystemFillColorSuccessBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12,4"
                                VerticalAlignment="Top"
                                AutomationProperties.Name="Service status">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Ellipse x:Name="StatusIndicator" Width="8" Height="8"
                                         Fill="{ThemeResource SystemFillColorSuccessBrush}"
                                         VerticalAlignment="Center"/>
                                <TextBlock x:Name="StatusText" Text="Running"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                    Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock x:Name="ListeningUrlText"
                                       Text="http://localhost:5200"
                                       Style="{StaticResource MonoTextStyle}"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Button x:Name="CopyLocalUrlButton"
                                    Click="OnCopyLocalUrlClicked"
                                    Padding="8"
                                    ToolTipService.ToolTip="Copy URL"
                                    AutomationProperties.Name="Copy local MCP URL">
                                <SymbolIcon Symbol="Copy"/>
                            </Button>
                        </StackPanel>

                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                   x:Name="LocalDeviceInfoText"
                                   Text=""
                                   Style="{StaticResource CaptionMutedStyle}"/>
                    </Grid>
                </Border>

                <!-- ========== TWO-COLUMN BODY ========== -->
                <Grid x:Name="BodyGrid" ColumnSpacing="20" RowSpacing="20">
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup>
                            <!-- Narrow: stack both columns vertically. -->
                            <VisualState x:Name="NarrowState">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="0"/>
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="LeftColumn.Width" Value="*"/>
                                    <Setter Target="RightColumn.Width" Value="0"/>
                                    <Setter Target="FirstRow.Height" Value="Auto"/>
                                    <Setter Target="SecondRow.Height" Value="Auto"/>
                                    <Setter Target="RightPanel.(Grid.Column)" Value="0"/>
                                    <Setter Target="RightPanel.(Grid.Row)" Value="1"/>
                                </VisualState.Setters>
                            </VisualState>
                            <!-- Wide: side-by-side. -->
                            <VisualState x:Name="WideState">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="900"/>
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="LeftColumn.Width" Value="*"/>
                                    <Setter Target="RightColumn.Width" Value="380"/>
                                    <Setter Target="FirstRow.Height" Value="Auto"/>
                                    <Setter Target="SecondRow.Height" Value="0"/>
                                    <Setter Target="RightPanel.(Grid.Column)" Value="1"/>
                                    <Setter Target="RightPanel.(Grid.Row)" Value="0"/>
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="LeftColumn" Width="*"/>
                        <ColumnDefinition x:Name="RightColumn" Width="380"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="FirstRow" Height="Auto"/>
                        <RowDefinition x:Name="SecondRow" Height="0"/>
                    </Grid.RowDefinitions>

                    <!-- ─────────── LEFT ─────────── -->
                    <StackPanel Grid.Column="0" Spacing="20">

                        <!-- Connected sessions -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <SymbolIcon Grid.Column="0" Symbol="Contact"
                                                VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Connected sessions"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                    <controls:InfoBadge Grid.Column="2"
                                                        x:Name="SessionsBadge"
                                                        Value="0"
                                                        VerticalAlignment="Center"/>
                                </Grid>

                                <ListView x:Name="SessionsList"
                                          Style="{StaticResource FlatListViewStyle}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,6" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                                         Fill="{Binding StatusColor}"
                                                         VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Spacing="2"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding Details}"
                                                               Style="{StaticResource CaptionMutedStyle}"/>
                                                </StackPanel>
                                                <Border Grid.Column="2"
                                                        Visibility="{Binding ActiveVisibility}"
                                                        Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                                                        BorderBrush="{ThemeResource SystemFillColorAttentionBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10" Padding="8,2"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="Active"
                                                               Style="{StaticResource CaptionTextBlockStyle}"/>
                                                </Border>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <StackPanel x:Name="NoSessionsPanel"
                                            Spacing="6"
                                            HorizontalAlignment="Center"
                                            Padding="0,20">
                                    <SymbolIcon Symbol="Contact" Opacity="0.35"
                                                HorizontalAlignment="Center"/>
                                    <TextBlock Text="No sessions connected yet"
                                               Style="{StaticResource CaptionMutedStyle}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="Apps running the zRover SDK will appear here."
                                               Style="{StaticResource CaptionMutedStyle}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Connected MCP clients -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0"
                                              FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                              Glyph="&#xE968;"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Connected MCP clients"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                    <controls:InfoBadge Grid.Column="2"
                                                        x:Name="ControllersBadge"
                                                        Value="0"
                                                        VerticalAlignment="Center"/>
                                </Grid>

                                <ListView x:Name="ControllersList"
                                          Style="{StaticResource FlatListViewStyle}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,6" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                                         Fill="{ThemeResource SystemFillColorSuccessBrush}"
                                                         VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Spacing="2"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayText}"/>
                                                    <TextBlock Text="{Binding DetailText}"
                                                               Style="{StaticResource CaptionMutedStyle}"/>
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <StackPanel x:Name="NoControllersPanel"
                                            Spacing="6"
                                            HorizontalAlignment="Center"
                                            Padding="0,16">
                                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                              Glyph="&#xE968;" Opacity="0.35"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="No MCP clients connected"
                                               Style="{StaticResource CaptionMutedStyle}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Remote retrievers (controlled + saved) -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="12">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <SymbolIcon Grid.Column="0" Symbol="Globe"
                                                VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="Remote retrievers"
                                               Style="{StaticResource SectionTitleStyle}"/>
                                    <controls:InfoBadge Grid.Column="2"
                                                        x:Name="ManagersBadge"
                                                        Value="0"
                                                        VerticalAlignment="Center"/>
                                </Grid>

                                <ListView x:Name="ManagersList"
                                          Style="{StaticResource FlatListViewStyle}">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Padding="0,6" ColumnSpacing="12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                                         Fill="{Binding StatusColor}"
                                                         VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Spacing="2"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding DetailText}"
                                                               Style="{StaticResource CaptionMutedStyle}"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" Content="Disconnect"
                                                        Tag="{Binding ManagerId}"
                                                        Click="OnDisconnectManagerClicked"
                                                        AutomationProperties.Name="{Binding DisconnectAutomationName}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <StackPanel x:Name="NoManagersPanel"
                                            Spacing="6"
                                            HorizontalAlignment="Center"
                                            Padding="0,16">
                                    <SymbolIcon Symbol="Globe" Opacity="0.35"
                                                HorizontalAlignment="Center"/>
                                    <TextBlock Text="No remote retrievers connected"
                                               Style="{StaticResource CaptionMutedStyle}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <!-- Saved / past -->
                                <StackPanel x:Name="PastManagersPanel"
                                            Spacing="8"
                                            Visibility="Collapsed">
                                    <Border Height="1"
                                            Background="{ThemeResource ControlStrokeColorDefaultBrush}"/>
                                    <TextBlock Text="Saved"
                                               Style="{StaticResource CaptionMutedStyle}"/>
                                    <ListView x:Name="PastManagersList"
                                              Style="{StaticResource FlatListViewStyle}">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Padding="0,4" ColumnSpacing="12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Ellipse Grid.Column="0" Width="8" Height="8"
                                                             Fill="{ThemeResource TextFillColorTertiaryBrush}"
                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding DisplayText}"
                                                               VerticalAlignment="Center"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                                    <Button Grid.Column="2" Content="Reconnect"
                                                            Tag="{Binding}"
                                                            Click="OnReconnectManagerClicked"
                                                            AutomationProperties.Name="{Binding ReconnectAutomationName}"/>
                                                    <Button Grid.Column="3" Content="Forget"
                                                            Tag="{Binding}"
                                                            Click="OnForgetManagerClicked"
                                                            Margin="4,0,0,0"
                                                            AutomationProperties.Name="{Binding ForgetAutomationName}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- ─────────── RIGHT ─────────── -->
                    <StackPanel x:Name="RightPanel" Grid.Column="1" Spacing="20">

                        <!-- External access -->
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel Spacing="16">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <SymbolIcon Grid.Column="0" Symbol="Share"
                                                VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="External access"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="Share this Retriever with another device on the network."
                                                   Style="{StaticResource CaptionMutedStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="2" x:Name="ExternalToggle"
                                                  Toggled="OnExternalToggled"
                                                  OnContent="" OffContent=""
                                                  MinWidth="0"
                                                  AutomationProperties.Name="Allow external connections"/>
                                </Grid>

                                <!-- Loading indicator: shown after enabling but before URL/QR are ready. -->
                                <StackPanel x:Name="ExternalLoadingPanel"
                                            Visibility="Collapsed"
                                            Spacing="12"
                                            HorizontalAlignment="Center"
                                            Padding="0,8">
                                    <ProgressRing IsActive="True" Width="28" Height="28"/>
                                    <TextBlock Text="Starting external listener&#x2026;"
                                               Style="{StaticResource CaptionMutedStyle}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel x:Name="ExternalInfoPanel"
                                            Visibility="Collapsed"
                                            Spacing="16">
                                    <Border Height="1"
                                            Background="{ThemeResource ControlStrokeColorDefaultBrush}"/>

                                    <Border Style="{StaticResource SubCardBorderStyle}"
                                            HorizontalAlignment="Stretch">
                                        <Image x:Name="QrCodeImage"
                                               Width="180" Height="180"
                                               HorizontalAlignment="Center"
                                               Stretch="Uniform"
                                               AutomationProperties.Name="QR code for connection link"
                                               AutomationProperties.HelpText="Scan with another device to connect to this Retriever."/>
                                    </Border>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Connection URL"
                                                   Style="{StaticResource CaptionMutedStyle}"/>
                                        <TextBlock x:Name="ExternalUrlText"
                                                   Style="{StaticResource MonoTextStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Bearer token"
                                                   Style="{StaticResource CaptionMutedStyle}"/>
                                        <TextBlock x:Name="ExternalTokenText"
                                                   Style="{StaticResource MonoTextStyle}"
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <Button x:Name="CopyLinkButton"
                                            Click="OnCopyLinkClicked"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            HorizontalAlignment="Stretch">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <SymbolIcon Symbol="Copy"/>
                                            <TextBlock Text="Copy connection link"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Advanced toggles -->
                        <Border Style="{StaticResource CardBorderStyle}" Padding="16">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0"
                                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                          Glyph="&#xE7B8;"
                                          VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="Package install and uninstall"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Let MCP clients install or remove MSIX packages."
                                               Style="{StaticResource CaptionMutedStyle}"/>
                                </StackPanel>
                                <ToggleSwitch Grid.Column="2"
                                              x:Name="PackageInstallToggle"
                                              Toggled="OnPackageInstallToggled"
                                              OnContent="" OffContent=""
                                              MinWidth="0"
                                              AutomationProperties.Name="Allow MCP clients to install or uninstall packages"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Grid>

                <!-- ========== FOOTER ========== -->
                <StackPanel Orientation="Horizontal" Spacing="4" Padding="4,8,0,0">
                    <HyperlinkButton Content="Privacy"
                                     NavigateUri="https://github.com/arcadiogarcia/zRover/blob/main/docs/privacy.md"/>
                    <TextBlock Text="·" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <HyperlinkButton Content="Security"
                                     NavigateUri="https://github.com/arcadiogarcia/zRover/blob/main/docs/security.md"/>
                    <TextBlock Text="·" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <HyperlinkButton Content="Source code"
                                     NavigateUri="https://github.com/arcadiogarcia/zRover"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>